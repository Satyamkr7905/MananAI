# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — real secrets must NEVER be committed.

# --- Google Gemini (optional; offline hints work without this) ---
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Set to "off" to fully disable LLM-powered hints.
USE_LLM_HINTS=auto

# --- Logging ---
LOG_LEVEL=INFO

# --- FastAPI server (``python -m uvicorn server.main:app --reload --host 127.0.0.1 --port 8000``) ---
# APP_ENV controls production safety rails.
#   dev  — allows running without a strong JWT_SECRET and returns the OTP in
#          the /send-otp response body when SMTP is unavailable.
#   prod — refuses to start with an insecure JWT_SECRET and NEVER returns the
#          OTP in HTTP responses (you MUST configure SMTP).
APP_ENV=dev

# PostgreSQL (default). Create DB and user first, e.g.:
#   createuser -P adaptive
#   createdb -O adaptive adaptive_dsa_tutor
# URL-encode special characters in the password (e.g. @ -> %40).
# DATABASE_URL=postgresql+psycopg://adaptive:adaptive@127.0.0.1:5432/adaptive_dsa_tutor
# SQLite (optional) — use an absolute path on Windows, e.g.:
# DATABASE_URL=sqlite:///C:/path/to/tutor_api.db

# REQUIRED in APP_ENV=prod. Must be a random string of at least 32 chars.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=b03127b324e681a5279cd1ea747f0a979cdce7872b96496c42132fa9e5023233
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OTP brute-force protection (tune only if you know what you're doing):
# OTP_MAX_ATTEMPTS=5
# OTP_SEND_COOLDOWN_SECONDS=30
# OTP_SEND_DAILY_MAX=20

# Gmail SMTP for real OTP emails (optional — without these, dev mode shows the OTP in the UI)
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# If port 587 (STARTTLS) is blocked, try: GMAIL_SMTP_PORT=465
# GMAIL_SMTP_TIMEOUT_SECONDS=20
