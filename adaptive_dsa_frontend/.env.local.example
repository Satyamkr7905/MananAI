# copy this to `.env.local` (gitignored) and uncomment what you need.

# FastAPI backend URL. required — frontend don't run without it.
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# same Web client ID as the backend GOOGLE_CLIENT_ID (from Google Cloud Console).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
