# Copy this file to `.env.local` (gitignored) and uncomment the variables you need.

# Point to a live backend. If unset or NEXT_PUBLIC_USE_MOCK_API=true,
# the UI runs fully on mock data.
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Same Web client ID as the FastAPI server GOOGLE_CLIENT_ID (Google Cloud Console).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Force mock data even when API_BASE is set (handy for UI iteration).
# NEXT_PUBLIC_USE_MOCK_API=true

# Optional: enable agent debug posts to a local ingest server (adds work per request).
# NEXT_PUBLIC_DEBUG_AGENT_LOG=true
